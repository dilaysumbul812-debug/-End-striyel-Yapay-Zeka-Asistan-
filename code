@app.route('/')
def index():
    if not os.path.exists(RAPOR_KLASORU):
        os.makedirs(RAPOR_KLASORU)

    dosyalar = [f for f in os.listdir(RAPOR_KLASORU) if f.endswith('.pdf')]
    dosyalar_with_time = []
    for f in dosyalar:
        fp = os.path.join(RAPOR_KLASORU, f)
        dosyalar_with_time.append((f, os.path.getmtime(fp)))
    dosyalar_with_time.sort(key=lambda x: x[1], reverse=True)

    aylar_tr = {
        1: "Ocak", 2: "Şubat", 3: "Mart", 4: "Nisan",
        5: "Mayıs", 6: "Haziran", 7: "Temmuz", 8: "Ağustos",
        9: "Eylül", 10: "Ekim", 11: "Kasım", 12: "Aralık"
    }

    grouped_files = defaultdict(lambda: defaultdict(lambda: defaultdict(list)))
    for f, mtime in dosyalar_with_time:
        dt = datetime.fromtimestamp(mtime)
        grouped_files[dt.year][aylar_tr[dt.month]][dt.day].append(f)

    return render_template_string(HTML_TEMPLATE, grouped_files=grouped_files)

@app.route('/download/<filename>')
def indir(filename):
    return send_from_directory(RAPOR_KLASORU, filename)

@app.route('/api/chat', methods=['POST'])
def chat_api():
    client_ip = request.remote_addr
    data = request.get_json()
    msg = data.get('message', '').strip()
    if not msg:
        return jsonify({"response": "Lütfen bir soru yazın."})
    
    response = chatbot_engine.process_message(msg)
    
    print(f"\n{'='*50}")
    print(f"🌍 İstek Yapan IP: {client_ip}")
    print(f"👤 Gelen Soru    : {msg}")
    print(f"🤖 LLM Cevabı    : {response}")
    print(f"{'='*50}\n")
    
    return jsonify({"response": response})


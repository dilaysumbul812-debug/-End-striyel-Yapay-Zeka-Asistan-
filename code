class ChatbotEngine:
    def __init__(self):
        self.uretim = None
        self.ariza = None
        
        self._chat_history = []
        self._last_period = 30  
        self._last_machine = None
        self._last_barcode = None
        self._last_route = None    
        self._last_alarm = None    
        
        self._load_data()

    def _load_data(self):
        try:
            u_path = URETIM_EXCEL 
            a_path = ARIZA_EXCEL 
            
            if not os.path.exists(u_path) or not os.path.exists(a_path):
                # Dosya yoksa boş dataframe oluştur ki sistem çökmesin
                self.uretim = pd.DataFrame()
                self.ariza = pd.DataFrame()
                self._last_load_time = time.time()
                return

            uretim = pd.read_excel(u_path)
            ariza = pd.read_excel(a_path)

            # Sütun isim standardizasyonu
            uretim.rename(columns={'makine_kimlik': 'Makinekimlik', 'basladi_tarih': 'Basladi_tarih'}, inplace=True)
            ariza.rename(columns={'makine_kimlik': 'Makinekimlik'}, inplace=True)

            gecerli = [str(k) for k in MACHINE_NAME_MAP.keys()]
            uretim = uretim[uretim['Makinekimlik'].astype(str).str.replace('.0','',regex=False).isin(gecerli)]
            ariza  = ariza[ariza['Makinekimlik'].astype(str).str.replace('.0','',regex=False).isin(gecerli)]
            uretim['Makinekimlik'] = uretim['Makinekimlik'].astype(str).str.replace('.0','',regex=False).astype(int)
            ariza['Makinekimlik']  = ariza['Makinekimlik'].astype(str).str.replace('.0','',regex=False).astype(int)

            cols_to_keep = ['ID','Basladi_tarih','start_tarih','stop_tarih','uretimadet','Makinekimlik','uretim_sure_sn',
                            'siparis_no', 'etiket', 'personel', 'birinci_kalite', 'ikinci_kalite', 'tamir']
            existing_cols = [c for c in cols_to_keep if c in uretim.columns]
            uretim = uretim[existing_cols]

            rename_map = {'ID': 'id', 'Basladi_tarih': 'basladi', 'start_tarih': 'start', 'stop_tarih': 'stop', 'uretim_sure_sn': 'sure'}
            uretim.rename(columns=rename_map, inplace=True)
            ariza = ariza[['id','ariza_zaman','ariza_aciklama','Makinekimlik']]
            ariza.columns = ['id','ariza_zaman','aciklama','Makinekimlik']

            uretim['start'] = pd.to_datetime(uretim['start'])
            uretim['stop']  = pd.to_datetime(uretim['stop'])
            ariza['ariza_zaman'] = pd.to_datetime(ariza['ariza_zaman'])
            uretim['date'] = uretim['start'].dt.date
            ariza['date']  = ariza['ariza_zaman'].dt.date

            uretim = uretim.sort_values(['Makinekimlik', 'start'])
            uretim['onceki_stop'] = uretim.groupby(['date', 'Makinekimlik'])['stop'].shift(1)
            uretim['mudahale_suresi_sn'] = (uretim['start'] - uretim['onceki_stop']).dt.total_seconds()
            uretim['mudahale_suresi_sn'] = uretim['mudahale_suresi_sn'].apply(lambda x: x if pd.notnull(x) and 0 <= x <= 3600 else 0)

            a_sorted = ariza.sort_values('ariza_zaman').copy()
            u_sorted = uretim.sort_values('start').copy()
            merged = pd.merge_asof(
                u_sorted, 
                a_sorted[['ariza_zaman', 'Makinekimlik']], 
                left_on='start', 
                right_on='ariza_zaman', 
                by='Makinekimlik',
                direction='backward'
            )
            merged['durus_tipi'] = 'Operatör'
            mask = (merged['ariza_zaman'] >= merged['onceki_stop']) & (merged['ariza_zaman'] <= merged['start'])
            merged.loc[mask, 'durus_tipi'] = 'Makine'
            uretim = merged

            # Bakım testi temizliği (Genel 17:00 mesai sonu)
            import datetime as dt_mod
            sinir = dt_mod.time(17, 0)
            sil_u, sil_a = [], []
            for gun in uretim['start'].dt.date.unique():
                gu = uretim[uretim['start'].dt.date == gun]
                ms = gu[gu['start'].dt.time > sinir]
                if not ms.empty and len(ms['Makinekimlik'].unique()) < 6:
                    sil_u.extend(ms.index.tolist())
                    ga = ariza[ariza['ariza_zaman'].dt.date == gun]
                    ma = ga[(ga['ariza_zaman'].dt.time > sinir) & (ga['Makinekimlik'].isin(ms['Makinekimlik'].unique()))]
                    sil_a.extend(ma.index.tolist())
            uretim = uretim.drop(sil_u)
            ariza  = ariza.drop(sil_a)

            self.uretim = uretim
            self.ariza  = ariza
            self._last_load_time = time.time()
            print(f"✅ Chatbot verisi yüklendi — Üretim: {len(uretim)} satır, Arıza: {len(ariza)} satır")
        except Exception as e:
            print(f"❌ Chatbot veri yükleme hatası: {e}")
            traceback.print_exc()

    def _ensure_fresh(self):
        if self._last_load_time is None or (time.time() - self._last_load_time) > 3600:
            self._load_data()

    def _resolve_machines(self, text):
        machines = []
        # Jenerik makine formatı tespiti (MAKINE-1, MAKİNE 1 vs)
        matches = re.finditer(r'[Mm][Aa][Kk][İiIi][Nn][Ee]\s*[-–]?\s*(\d+)', text)
        for m in matches:
            tid = 100 + int(m.group(1)) # ID mapping'e uygun hale getir
            if tid in MACHINE_NAME_MAP and tid not in machines:
                machines.append(tid)
        
        # Nolu/Numaralı makine
        matches_num = re.finditer(r'(\d+)\s*(?:nolu|numaralı|\.?\s*makine)', text.lower())
        for m in matches_num:
            tid = 100 + int(m.group(1))
            if tid in MACHINE_NAME_MAP and tid not in machines:
                machines.append(tid)
        return machines

    def _resolve_machine(self, text):
        m = self._resolve_machines(text)
        if m:
            self._last_machine = m[0]
            return m[0]
        
        takip_kelimeleri = {r"\bbu makine\b", r"\bonun\b", r"\bbunun\b", r"\bpeki\b", r"\baynı makine\b", r"\bo makine\b", r"\bbu makinenin\b"}
        if self._last_machine and any(re.search(w, text.lower()) for w in takip_kelimeleri):
            return self._last_machine
        return None

    def _resolve_barcode(self, text):
        match = re.search(r'S?\d+_\d+(?:\s+[A-Z]\d+-\d+)?', text)
        if match: return match.group(0)
        return None

    def _resolve_period(self, text):
        t = text.lower()
        date_pattern = r'(\d{1,2})[\./-](\d{1,2})[\./-](\d{4})'
        date_range = re.findall(f'{date_pattern}\\s*(?:-|ile|ve|\\s+)\\s*{date_pattern}', t)
        if date_range:
            try:
                start_d, start_m, start_y = int(date_range[0][0]), int(date_range[0][1]), int(date_range[0][2])
                end_d, end_m, end_y = int(date_range[0][3]), int(date_range[0][4]), int(date_range[0][5])
                start_date = date(start_y, start_m, start_d)
                end_date = date(end_y, end_m, end_d)
                if start_date > end_date: start_date, end_date = end_date, start_date
                return {"type": "range", "start": start_date, "end": end_date}
            except: pass
        else:
            single_date = re.search(date_pattern, t)
            if single_date:
                try:
                    d, m, y = int(single_date.group(1)), int(single_date.group(2)), int(single_date.group(3))
                    dt = date(y, m, d)
                    return {"type": "range", "start": dt, "end": dt}
                except: pass
        
        aylar = {"ocak": 1, "şubat": 2, "mart": 3, "nisan": 4, "mayıs": 5, "haziran": 6, "temmuz": 7, "ağustos": 8, "eylül": 9, "ekim": 10, "kasım": 11, "aralık": 12}
        for ay_ad, ay_no in aylar.items():
            if ay_ad in t and "ay" in t: return {"type": "specific_month", "month": ay_no}
            
        if any(w in t for w in ["tüm zaman","şu ana kadar","tüm veri","toplam veri"]): return {"type": "all"}
        
        def word_to_num(w):
            words = {"bir":1, "iki":2, "üç":3, "dört":4, "beş":5, "altı":6, "yedi":7, "sekiz":8, "dokuz":9, "on":10}
            return words.get(w, 1)

        num_p = r'(\d+|bir|iki|üç|dört|beş|altı|yedi|sekiz|dokuz|on)'
        
        if "bu ay" in t: return {"type": "this_month"}
        if any(w in t for w in ["geçen ay", "geçtiğimiz ay"]): return {"type": "last_month"}
        if any(w in t for w in ["bu hafta"]): return {"type": "this_week"}
        if any(w in t for w in ["geçen hafta", "geçtiğimiz hafta"]): return {"type": "last_week"}
        if "bugün" in t: return {"type": "today"}
        if "dün" in t: return {"type": "yesterday"}
        
        m = re.search(f'son\\s*{num_p}\\s*ay', t)
        if m: return {"type": "days", "days": (int(m.group(1)) if m.group(1).isdigit() else word_to_num(m.group(1))) * 30}
            
        m = re.search(f'son\\s*{num_p}\\s*hafta', t)
        if m: return {"type": "days", "days": (int(m.group(1)) if m.group(1).isdigit() else word_to_num(m.group(1))) * 7}
            
        m = re.search(f'son\\s*{num_p}\\s*gün', t)
        if m: return {"type": "days", "days": (int(m.group(1)) if m.group(1).isdigit() else word_to_num(m.group(1)))}
            
        return self._last_period if self._last_period else {"type": "days", "days": 30}

    def _get_period_text(self, period):
        if not isinstance(period, dict): return "Seçilen Dönem"
        if period.get("type") == "days": return f"Son {period.get('days', 30)} Gün"
        if period.get("type") == "range": return f"{period['start'].strftime('%d.%m.%Y')} - {period['end'].strftime('%d.%m.%Y')} Dönemi"
        if period.get("type") == "specific_month":
            aylar_tr = {1:"Ocak",2:"Şubat",3:"Mart",4:"Nisan",5:"Mayıs",6:"Haziran",7:"Temmuz",8:"Ağustos",9:"Eylül",10:"Ekim",11:"Kasım",12:"Aralık"}
            return f"{aylar_tr.get(period['month'], '')} Ayı"
        if period.get("type") == "yesterday": return "Dün"
        if period.get("type") == "today": return "Bugün"
        if period.get("type") == "this_month": return "Bu Ay"
        if period.get("type") == "last_month": return "Geçen Ay"
        if period.get("type") == "this_week": return "Bu Hafta"
        if period.get("type") == "last_week": return "Geçen Hafta"
        if period.get("type") == "all": return "Tüm Zamanlar"
        return "Seçilen Dönem"

    def _filter(self, df, period):
        if df is None or df.empty or period is None: return df
        today = datetime.now().date()
        if not isinstance(period, dict): return df
        if period["type"] == "all": return df
        if period["type"] == "this_month": return df[df['date'].apply(lambda x: x.month == today.month and x.year == today.year)]
        if period["type"] == "specific_month":
            y = today.year
            if period["month"] > today.month: y -= 1
            return df[df['date'].apply(lambda x: x.month == period["month"] and x.year == y)]
        if period["type"] == "range": return df[(df['date'] >= period["start"]) & (df['date'] <= period["end"])]
        if period["type"] == "today": return df[df['date'] == today]
        if period["type"] == "yesterday": return df[df['date'] == today - timedelta(days=1)]
        if period["type"] == "this_week":
            start = today - timedelta(days=today.weekday())
            return df[(df['date'] >= start) & (df['date'] <= today)]
        if period["type"] == "last_week":
            start = today - timedelta(days=today.weekday() + 7)
            end = start + timedelta(days=6)
            return df[(df['date'] >= start) & (df['date'] <= end)]
        if period["type"] == "last_month":
            first_day = (today.replace(day=1) - timedelta(days=1)).replace(day=1)
            last_day = today.replace(day=1) - timedelta(days=1)
            return df[(df['date'] >= first_day) & (df['date'] <= last_day)]
        
        start = today - timedelta(days=period.get("days", 30))
        return df[(df['date'] >= start) & (df['date'] <= today)]

    def _daily_prod(self, u):
        if u.empty: return pd.DataFrame(columns=['date','Makinekimlik','uretim'])
        u = u.copy()
        u['uretimadet_num'] = pd.to_numeric(u['uretimadet'], errors='coerce').fillna(0)
        r = u.groupby(['date', 'Makinekimlik'])['uretimadet_num'].sum().reset_index()
        r.rename(columns={'uretimadet_num': 'uretim'}, inplace=True)
        return r[['date', 'Makinekimlik', 'uretim']]


                b_1kalite = int(pd.to_numeric(u_b['birinci_kalite'], errors='coerce').fillna(0).sum()) if 'birinci_kalite' in u_b.columns else 0
                b_2kalite = int(pd.to_numeric(u_b['ikinci_kalite'], errors='coerce').fillna(0).sum()) if 'ikinci_kalite' in u_b.columns else 0
                b_tamir = int(pd.to_numeric(u_b['tamir'], errors='coerce').fillna(0).sum()) if 'tamir' in u_b.columns else 0
                b_makineler = ", ".join([get_machine_name(m) for m in u_b['Makinekimlik'].unique()])
                b_tarih_min = u_b['date'].min()
                b_tarih_max = u_b['date'].max()
                
                p2_str = pt_str = ""
                if 'personel' in u_b.columns and 'ikinci_kalite' in u_b.columns:
                    u_b_kalite = u_b.copy()
                    u_b_kalite['ikinci_kalite_num'] = pd.to_numeric(u_b_kalite['ikinci_kalite'], errors='coerce').fillna(0)
                    u_b_kalite['tamir_num'] = pd.to_numeric(u_b_kalite['tamir'], errors='coerce').fillna(0)
                    p2_counts = u_b_kalite.groupby('personel')['ikinci_kalite_num'].sum()
                    p2_counts = p2_counts[p2_counts > 0].sort_values(ascending=False)
                    if not p2_counts.empty: p2_str = "\n".join([f"  - {p}: {int(c)} adet" for p, c in p2_counts.items() if str(p).strip()])
                    pt_counts = u_b_kalite.groupby('personel')['tamir_num'].sum()
                    pt_counts = pt_counts[pt_counts > 0].sort_values(ascending=False)
                    if not pt_counts.empty: pt_str = "\n".join([f"  - {p}: {int(c)} adet" for p, c in pt_counts.items() if str(p).strip()])

                ctx += f"Üretildiği Makineler: {b_makineler}\nÜretim Tarih Aralığı: {b_tarih_min} ile {b_tarih_max}\nÇalışan Operatörler: {personel_str}\nToplam Üretim: {b_uretim} adet\n"
                ctx += f"1. Kalite Ürün: {b_1kalite} adet\n2. Kalite Ürün: {b_2kalite} adet\n"
                if p2_str: ctx += f"2. Kalite Ürünleri Üreten Operatörler:\n{p2_str}\n"
                ctx += f"Tamir Edilen: {b_tamir} adet\n"
                if pt_str: ctx += f"Tamir İşlemi Yapan Operatörler:\n{pt_str}\n"
                ctx += "\n"
            else:
                ctx += f"[SİPARİŞ / BARKOD DETAYI: {barcode}]\nBu döneme ait '{barcode}' barkoduyla eşleşen hiçbir kayıt bulunamadı.\n\n"

        return ctx

    def _ask_llm(self, data_context, question, chat_history, route="GENEL"):
        history_text = ""
        if chat_history:
            history_text = "<chat_history>\n"
            for q, a in chat_history:
                history_text += f"Kullanıcı: {q}\nAsistan: {a}\n\n"
            history_text += "</chat_history>"

        rules_text = ROUTE_RULES.get(route, ROUTE_RULES["GENEL"])
        prompt = f"<system_role>\n{SYSTEM_IDENTITY}\n</system_role>\n<rules>\n{rules_text}\n</rules>\n<data_context>\n{data_context}\n</data_context>\n{history_text}\n<user_question>\n{question}\n</user_question>\nCevabını yalnızca düz metin olarak ver:"
        
        try:
            resp = http_requests.post(OLLAMA_URL, json={
                "model": "llama3.1", "prompt": prompt, "stream": False,
                "options": {"temperature": 0.0, "top_p": 0.1}
            }, timeout=240)
            if resp.status_code == 200:
                answer = resp.json().get('response', '').strip()
                if answer: return answer
        except Exception as e: print(f"⚠️ LLM hatası: {e}")
        return f"Şu an zeka modelim kapalı. Ancak sorduğunuz dönemin verileri şu şekilde:\n\n{data_context}"

    def _semantic_route(self, msg):
        m = msg.lower()
        sohbet_keys = ["merhaba", "selam", "nasılsın", "teşekkür", "sağ ol", "günaydın", "iyi günler", "hoşça kal", "görüşürüz"]
        veri_keys = ["üretim", "arıza", "alarm", "makine", "sipariş", "performans", "operatör", "kalite", "tamir", "duruş", "adet", "rapor", "koptu"]
        if any(k in m for k in sohbet_keys) and not any(k in m for k in veri_keys): return ("ODAKLI", "SOHBET")
        
        kapsamli_keys = ["rapor", "özet", "genel performans", "genel durum", "nasıldır", "nasıldı", "değerlendir", "analiz et", "enler", "en'ler", "kapsayan", "tüm veriler", "genel olarak"]
        domain_hits = sum([
            any(k in m for k in ["üretim", "adet", "verimli", "en iyi makine", "en kötü makine"]),
            any(k in m for k in ["alarm", "arıza", "duruş", "hata", "koptu"]),
            any(k in m for k in ["sipariş", "barkod", "ürün"]),
            any(k in m for k in ["operatör", "personel", "kalite", "tamir"]),
        ])
        if any(k in m for k in kapsamli_keys) or domain_hits >= 2: return ("KAPSAMLI", "GENEL")
        
        if self._resolve_barcode(msg): return ("ODAKLI", "SIPARIS")
        siparis_keys = ["sipariş", "barkod", "ürün", "etiket"]
        if any(k in m for k in siparis_keys): return ("ODAKLI", "SIPARIS")
        
        ariza_keys = ["alarm", "arıza", "koptu", "kopma", "sensör", "duruş", "hata", "rezerve", "buton", "kolon", "pause", "gripper", "çözüm", "tavsiye", "ip koptu", "ip takıldı"]
        if any(k in m for k in ariza_keys): return ("ODAKLI", "ARIZA")
        
        personel_keys = ["operatör", "personel", "kalite", "tamir", "kim yaptı", "kim üret", "hangi işçi", "geç başla", "erken bırak", "disiplin"]
        if any(k in m for k in personel_keys): return ("ODAKLI", "PERSONEL")
        
        if self._resolve_machines(msg): return ("ODAKLI", "MAKINE")
        
        devam_keys = ["bu alarm", "bu arıza", "bu makine", "bu sipariş", "hangi makinede", "hangi makinada", "hangisinde", "kaç defa", "kaç kez", "ne kadar", "peki"]
        if any(k in m for k in devam_keys) and self._last_route: return ("ODAKLI", self._last_route)
        
        return ("KAPSAMLI", "GENEL")

    def _slice_context(self, full_context, keep_sections, period_text="Seçilen Dönem"):
        result = f"=== VERİ BAĞLAMI ===\nAnaliz Dönemi: {period_text}\n\n"
        for section_name in keep_sections:
            if section_name in full_context:
                start = full_context.index(section_name)
                all_section_markers = ["[GENEL ÜRETİM]", "[GÜNLÜK ÜRETİM VE ARIZA ÖZETİ]", "[MAKİNE BAZLI ÜRETİM (Sıralı)]", "[ARIZA / ALARM BİLGİLERİ]", "[DURUŞ ANALİZİ", "[ARIZA TRENDİ]", "[PERSONEL / OPERATÖR PERFORMANSI]"]
                for mid in MACHINE_NAME_MAP.values(): all_section_markers.append(f"[{mid} DETAYLI BİLGİ]")
                all_section_markers.append("[SİPARİŞ / BARKOD DETAYI:")
                
                next_starts = [full_context.index(m) for m in all_section_markers if m in full_context and full_context.index(m) > start]
                end = min(next_starts) if next_starts else len(full_context)
                result += full_context[start:end]
        return result.strip()

    def _build_ariza_context(self, full_context, period_text):
        return self._slice_context(full_context, ["[ARIZA / ALARM BİLGİLERİ]", "[DURUŞ ANALİZİ", "[ARIZA TRENDİ]"], period_text)
    
    def _build_siparis_context(self, full_context, barcode, period_text):
        marker = f"[SİPARİŞ / BARKOD DETAYI: {barcode}]"
        if marker in full_context:
            section = full_context[full_context.index(marker):]
            return f"=== VERİ BAĞLAMI ===\nSorgu: Sipariş/Barkod '{barcode}' detayları\n\n{section}"
        return f"=== VERİ BAĞLAMI ===\n'{barcode}' barkoduyla eşleşen kayıt bulunamadı."
    
    def _build_makine_context(self, full_context, makine_id, period_text):
        isim = get_machine_name(makine_id)
        machine_marker = f"[{isim} DETAYLI BİLGİ]"
        result = self._slice_context(full_context, ["[GENEL ÜRETİM]", "[MAKİNE BAZLI ÜRETİM (Sıralı)]", "[ARIZA / ALARM BİLGİLERİ]"], period_text)
        if machine_marker in full_context:
            start = full_context.index(machine_marker)
            next_markers = ["[SİPARİŞ / BARKOD DETAYI:"]
            for mid in MACHINE_NAME_MAP.values():
                if mid != isim: next_markers.append(f"[{mid} DETAYLI BİLGİ]")
            next_starts = [full_context.index(m) for m in next_markers if m in full_context and full_context.index(m) > start]
            end = min(next_starts) if next_starts else len(full_context)
            result += "\n" + full_context[start:end]
        return result.strip()
    
    def _build_personel_context(self, full_context, makine_id, period_text):
        sections = ["[PERSONEL / OPERATÖR PERFORMANSI]"]
        if makine_id: sections.append(f"[{get_machine_name(makine_id)} DETAYLI BİLGİ]")
        return self._slice_context(full_context, sections, period_text)

    def process_message(self, msg):
        self._ensure_fresh()
        if self.uretim is None or self.ariza is None or self.uretim.empty: return "⚠️ Veri dosyaları yüklenemedi."
        
        try:
            mod, route = self._semantic_route(msg)
            print(f"🔀 Semantic Route: {mod} → {route}")
            
            period = self._resolve_period(msg)
            regex_makineler = self._resolve_machines(msg)
            regex_makine = regex_makineler[0] if regex_makineler else None
            regex_barkod = self._resolve_barcode(msg)
            
            makine_id = regex_makine or self._last_machine
            barcode = regex_barkod or (self._last_barcode if route == "SIPARIS" else None)
            
            is_siparis_sorusu = bool(re.search(r'\b(sipariş|barkod|ürün)\b', msg.lower()))
            if regex_makine and not is_siparis_sorusu: barcode = None
            
            if route == "SOHBET":
                data_context = "Kullanıcı sadece sohbet ediyor veya selam veriyor. Kısa ve nazikçe cevap ver, veriye girmene gerek yok."
                answer = self._ask_llm(data_context, msg, self._chat_history, route)
                self._chat_history.append((msg, answer))
                if len(self._chat_history) > 2: self._chat_history.pop(0)
                return answer
            
            full_context = self._build_data_context(period, makine_id, barcode)
            period_text = self._get_period_text(period)
            
            if mod == "ODAKLI":
                if route == "ARIZA": llm_context = self._build_ariza_context(full_context, period_text)
                elif route == "SIPARIS" and barcode: llm_context = self._build_siparis_context(full_context, barcode, period_text)
                elif route == "MAKINE" and makine_id: llm_context = self._build_makine_context(full_context, makine_id, period_text)
                elif route == "PERSONEL": llm_context = self._build_personel_context(full_context, makine_id, period_text)
                else:
                    llm_context = full_context
                    route = "GENEL"
            else:
                llm_context = full_context
                route = "GENEL"
            
            answer = self._ask_llm(llm_context, msg, self._chat_history, route)
            
            if makine_id: self._last_machine = makine_id
            if barcode: self._last_barcode = barcode
            self._last_period = period
            self._last_route = route
            
            self._chat_history.append((msg, answer))
            if len(self._chat_history) > 2: self._chat_history.pop(0)
            
            return answer
            
        except Exception as e:
            traceback.print_exc()
            return f"⚠️ İşlenirken hata: {str(e)}\n"

